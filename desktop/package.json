{
  "name": "quantlab-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "QuantLab Desktop shell for research, runtime visibility, and bounded AI assistance.",
  "main": "main.js",
  "scripts": {
    "prestart": "node -e \"const fs=require('fs'),p=require('path');const d=p.join(__dirname,'renderer','dist','index.html');if(!fs.existsSync(d)){console.error('\\n[quantlab-desktop] renderer/dist/index.html not found.\\nRun: npm run build\\n');process.exit(1);}\"",
    "start": "electron .",
    "start:legacy": "cross-env QUANTLAB_DESKTOP_RENDERER=legacy electron .",
    "dev": "concurrently \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "smoke": "npm run smoke:react:fallback",
    "smoke:legacy:fallback": "npm run build && node scripts/smoke.js --mode=fallback",
    "smoke:react:fallback": "npm run build && node scripts/smoke.js --mode=fallback --renderer=react",
    "smoke:real-path": "npm run build && node scripts/smoke.js --mode=real-path",
    "smoke:react:real-path": "npm run build && node scripts/smoke.js --mode=real-path --renderer=react",
    "mcp": "node mcp-server.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@types/node": "^24.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.11",
    "wait-on": "^8.0.5",
    "zod": "^4.1.12"
  }
}
